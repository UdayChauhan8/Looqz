{
  "manifest_version": 3,
  "name": "Looqz — Virtual Try-On",
  "short_name": "Looqz",
  "version": "1.0.0",
  "description": "Try on any clothing product instantly using AI. Browse any shopping site, click the extension, upload your photo, and see how clothes look on you!",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {},
  "background": {
    "service_worker": "src/background/service_worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/extractProductImage.ts", "src/content/popupOverlay.ts"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
