{
  "manifest_version": 3,
  "name": "Looqz — Virtual Try-On",
  "short_name": "Looqz",
  "version": "1.0.0",
  "description": "Try on any clothing product instantly using AI. Browse shopping sites, upload your photo, and see your new look!",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {},
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/extractProductImage.ts-loader--Ihbg0KP.js",
        "assets/popupOverlay.ts-loader-CuB6i7BU.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/*",
        "assets/extractProductImage.ts-1gzlAw_L.js",
        "assets/popupOverlay.ts-uEA0dIVl.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
