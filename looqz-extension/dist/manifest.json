{
  "manifest_version": 3,
  "name": "Looqz — Virtual Try-On",
  "version": "1.0.0",
  "description": "Try on any clothing product instantly using AI",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/extractProductImage.ts-loader--Ihbg0KP.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/*",
        "assets/extractProductImage.ts-1gzlAw_L.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
